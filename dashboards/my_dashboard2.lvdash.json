      "displayName": "answer_score",
      "queryLines": [
        "SELECT AVG(score) AS average_answer_score, Reputation, Id as UserId\r\n",
        "FROM data_platform_tutorial.default.marts_posts_users\r\n",
        "WHERE PostType=\"Answer\"\r\n",
        "GROUP BY Id, Reputation"
      ]
